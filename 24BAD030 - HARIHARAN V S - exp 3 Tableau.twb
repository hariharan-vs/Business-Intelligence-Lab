      <aliases enabled='yes' />
      <column caption='Postal Code Clean' datatype='integer' name='[Calculation_0434057839476743]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Postal Code], 0)' />
      </column>
      <column caption='Outlier Flag' datatype='string' name='[Calculation_0434057842556936]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 50000 THEN&#13;&#10;&quot;High Sales&quot;&#13;&#10;&#13;&#10;ELSEIF [Profit] &lt; -3000 THEN&#13;&#10;&quot;High Loss&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;&quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
